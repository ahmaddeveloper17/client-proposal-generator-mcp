{
  "name": "proposal-generator",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter @dev_ahmad_org/proposal-generator build && bun run --filter @dev_ahmad_org/proposal-generator-cli build",
    "build:server": "bun run --filter @dev_ahmad_org/proposal-generator build",
    "build:cli": "bun run --filter @dev_ahmad_org/proposal-generator-cli build",
    "dev": "bun run --filter @dev_ahmad_org/proposal-generator dev",
    "lint": "oxlint packages/ --fix",
    "lint:check": "oxlint packages/",
    "format": "oxfmt packages/",
    "format:check": "oxfmt --check packages/",
    "typecheck": "tsc --noEmit",
    "release:pack": "bun run --filter @dev_ahmad_org/proposal-generator pack:dry",
    "release:pack:cli": "bun run --filter @dev_ahmad_org/proposal-generator-cli pack:dry",
    "start": "bun run packages/server/dist/index.mjs",
    "preview": "bun run --filter @dev_ahmad_org/proposal-generator-cli preview"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.0"
  }
}
