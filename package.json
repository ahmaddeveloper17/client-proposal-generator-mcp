{
  "name": "proposal-generator",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter @proposal-generator/server build",
    "dev": "bun run --filter @proposal-generator/server dev",
    "lint": "oxlint packages/ --fix",
    "lint:check": "oxlint packages/",
    "format": "oxfmt packages/",
    "format:check": "oxfmt --check packages/",
    "typecheck": "tsc --noEmit",
    "release:pack": "bun run --filter @proposal-generator/server pack:dry",
    "start": "bun run packages/server/dist/index.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.0"
  }
}
