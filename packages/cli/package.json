{
  "name": "@dev_ahmad_org/proposal-generator-cli",
  "version": "1.0.8",
  "description": "CLI client for the proposal-generator — generate freelancing proposals from the terminal",
  "keywords": [
    "cli",
    "estimator",
    "freelance",
    "proposal"
  ],
  "license": "MIT",
  "bin": {
    "proposal-gen": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "pack:dry": "bun run build && bun pm pack --dry-run",
    "preview": "bun run build && node ./dist/index.js"
  },
  "dependencies": {
    "@dev_ahmad_org/proposal-generator": "1.0.5",
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "tsdown": "^0.22.0",
    "typescript": "^5.8.0"
  }
}
