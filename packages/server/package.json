{
  "name": "@proposal-generator",
  "version": "1.0.2",
  "description": "MCP server that turns client requirements into a timeline, tech stack, price estimate, milestones, and a proposal document",
  "keywords": [
    "freelance",
    "mcp",
    "model-context-protocol",
    "proposal"
  ],
  "license": "MIT",
  "bin": {
    "proposal-generator-mcp": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "pack:dry": "bun run build && bun pm pack --dry-run",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
